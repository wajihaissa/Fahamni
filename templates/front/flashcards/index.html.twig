{% extends 'front/base_front.html.twig' %}

{% block title %}Révision : {{ matiere.titre }}{% endblock %}

{% block stylesheets %}
    {# Keep parent styles #}
    {{ parent() }}
     
<style>
        /* =========================================
           1. LAYOUT & CONTAINER
           ========================================= */
        .study-wrapper {
            max-width: 700px;
            margin: 2rem auto;
        }

        .flashcard-static {
            background: #ffffff;
            border-radius: 24px; /* More rounded */
            padding: 40px;       /* More internal space */
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            min-height: 500px;   /* Taller card */
            display: flex;
            flex-direction: column;
            color: #1a1a2e;
            transition: all 0.3s ease;
        }

        /* Dark Theme Override */
        .dark-theme .flashcard-static {
            background: #1a1a2e;
            color: #ffffff;
            border: 1px solid rgba(255,255,255,0.05);
        }

        /* =========================================
           2. TYPOGRAPHY
           ========================================= */
        .step-counter {
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(10px);
            padding: 8px 24px;
            border-radius: 50px;
            font-weight: 700;
            font-size: 0.9rem;
            margin-bottom: 2rem;
            border: 1px solid rgba(255,255,255,0.2);
            display: inline-block;
        }

        .question-label {
            text-transform: uppercase;
            font-weight: 800;
            font-size: 0.75rem;
            opacity: 0.7;
            letter-spacing: 1.5px;
            margin-bottom: 12px;
            display: block; /* Ensures spacing */
        }

        .question-text {
            font-size: 2.2rem;
            font-weight: 800;
            line-height: 1.3;
            margin-bottom: 2.5rem;
        }

        /* =========================================
           3. THE INPUT BOX (FIXED)
           ========================================= */
        .answer-textarea {
            width: 100%;
            background-color: #f8fafc; 
            border: 2px solid #e2e8f0;
            border-radius: 16px;
            padding: 20px !important; /* Fixes "Crammed" text */
            font-size: 1.1rem;
            line-height: 1.6;
            color: #1a1a2e;
            resize: none;
            transition: all 0.2s ease;
        }

        .answer-textarea:focus {
            outline: none;
            background-color: #ffffff;
            border-color: #4e73df;
            box-shadow: 0 0 0 4px rgba(78, 115, 223, 0.15);
        }

        /* DARK THEME INPUT FIX */
        .dark-theme .answer-textarea {
            /* !important is needed to override Bootstrap's white background */
            background-color: #2d2d44 !important; 
            border-color: #4a4a6a !important;
            color: #ffffff !important; 
        }

        .dark-theme .answer-textarea:focus {
            background-color: #353550 !important;
            border-color: #4e73df !important;
        }
        
        .dark-theme .answer-textarea::placeholder {
            color: rgba(255,255,255,0.4);
        }

        /* =========================================
           4. FEEDBACK BOXES
           ========================================= */
        .ai-feedback-box {
            background: rgba(78, 115, 223, 0.1);
            border-left: 5px solid #4e73df;
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 24px;
        }

        .expected-answer-box {
            background: rgba(128, 128, 128, 0.05);
            border-radius: 12px;
            padding: 20px;
            border: 1px solid rgba(128,128,128, 0.1);
        }
    </style>
{% endblock %}

{% block content %}
<div class="container py-5">
    <div class="study-wrapper">


        <div style="margin-bottom: 20px; display: flex; align-items: center;">
    
    <a href="{{ path('app_front_subject_show', {'id': matiere.id}) }}" 
       class="btn btn-secondary" 
       style="background: #f1f5f9; color: #64748b; border: none; padding: 10px 20px; border-radius: 8px; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; transition: all 0.2s;">
        <i class="fas fa-arrow-left"></i> Back to {{ matiere.titre }}
    </a>

</div>
        
        {# Simple Progress Header #}
        <div class="text-center mb-5">
            <h1 class="fw-bold text-white mb-3">{{ matiere.titre }}</h1>
            <div class="step-counter text-white">
                {{ currentIndex + 1 }} / {{ totalCards }}
            </div>
        </div>

        <div class="flashcard-static">
            {% if not isFeedbackMode %}
                {# --- PHASE 1: INPUT --- #}
                <div class="mb-4">
                    <div class="question-label">Question</div>
                    <h2 class="question-text">{{ card.question }}</h2>
                </div>

                <form method="POST" 
                      action="{{ path('app_student_flashcards', { 'id': matiere.id, 'step': currentIndex }) }}" 
                      data-turbo="false" 
                      class="mt-auto">
                    
                    <div class="mb-4">
                        <label class="question-label">Ta Réponse</label>
                        <textarea name="user_answer" 
                                  class="form-control answer-textarea" 
                                  rows="5" 
                                  placeholder="Explique ce concept avec tes propres mots..." 
                                  required></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill py-3 fw-bold shadow">
                        Vérifier ma réponse <i class="fas fa-robot ms-2"></i>
                    </button>
                </form>

            {% else %}
                {# --- PHASE 2: FEEDBACK --- #}
                <div class="mb-4">
                    <div class="question-label">Question</div>
                    <h4 class="fw-bold mb-4">{{ card.question }}</h4>

                    <div class="ai-feedback-box">
                        <div class="question-label text-primary mb-2">
                            <i class="fas fa-magic me-2"></i>Analyse de l'IA
                        </div>
                        <p class="mb-0 fs-5">"{{ aiFeedback }}"</p>
                    </div>

                    <div class="expected-answer-box">
                        <div class="question-label mb-2">Réponse attendue</div>
                        <p class="mb-0 opacity-75 lead">{{ card.answer }}</p>
                    </div>
                </div>

                <div class="mt-auto">
                    {% if currentIndex + 1 < totalCards %}
                        <a href="{{ path('app_student_flashcards', { 'id': matiere.id, 'step': currentIndex + 1 }) }}" 
                           class="btn btn-dark btn-lg w-100 rounded-pill py-3 fw-bold shadow">
                            Question suivante <i class="fas fa-arrow-right ms-2"></i>
                        </a>
                    {% else %}
                        <div class="text-center py-3">
                            <h3 class="fw-bold mb-3">Félicitations ! 🎉</h3>
                            <p class="opacity-75 mb-4">Tu as terminé tes révisions pour {{ matiere.titre }}.</p>
                            <a href="{{ path('app_student_flashcards', {id: matiere.id, reset: 1}) }}" 
   class="btn btn-primary btn-lg rounded-pill px-5 fw-bold">
    Nouvelle Session
</a>

<a href="{{ path('app_front_subject_show', {id: matiere.id}) }}" class="d-block mt-3 text-muted">
    Retour au cours
</a>
                        </div>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}