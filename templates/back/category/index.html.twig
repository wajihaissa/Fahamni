{% extends 'back/admin_base.html.twig' %}

{% block title %}Categories - FAHIMNI Admin{% endblock %}

{% block body %}
<div style="padding: 2rem;">
    {# Header #}
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h1 style="font-size: 1.8rem; font-weight: 700; color: #1e293b; margin: 0;">Categories</h1>
            <p style="color: #64748b; margin: 5px 0 0 0;">Manage course topics and slugs</p>
        </div>
        <a href="{{ path('app_category_new') }}" style="background: linear-gradient(90deg, #7c6cff 0%, #6c5ce7 100%); color: white; padding: 0.75rem 1.5rem; border-radius: 8px; text-decoration: none; font-weight: 600; box-shadow: 0 4px 12px rgba(108, 92, 231, 0.25);">
            <i class="fas fa-plus"></i> New Category
        </a>
    </div>

    {# Table Card #}
    <div style="background: white; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); border: 1px solid #e2e8f0; overflow: hidden;">
        <table style="width: 100%; border-collapse: collapse;">
            <thead style="background: #f8fafc; border-bottom: 1px solid #e2e8f0;">
                <tr>
                    <th style="padding: 1rem 1.5rem; text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; font-weight: 600;">ID</th>
                    <th style="padding: 1rem 1.5rem; text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; font-weight: 600;">Name</th>
                    <th style="padding: 1rem 1.5rem; text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; font-weight: 600;">Slug</th>
                    <th style="padding: 1rem 1.5rem; text-align: right; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; color: #64748b; font-weight: 600;">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for category in categories %}
                <tr style="border-bottom: 1px solid #f1f5f9; transition: background 0.2s;">
                    <td style="padding: 1rem 1.5rem; color: #64748b;">#{{ category.id }}</td>
                    <td style="padding: 1rem 1.5rem; font-weight: 600; color: #1e293b;">{{ category.name }}</td>
                    <td style="padding: 1rem 1.5rem; color: #4f46e5; background: #eef2ff; border-radius: 4px; font-family: monospace; font-size: 0.9em;">{{ category.slug }}</td>
                    <td style="padding: 1rem 1.5rem; text-align: right;">
                        <a href="{{ path('app_category_edit', {'id': category.id}) }}" style="color: #64748b; margin-right: 10px; transition: color 0.2s;"><i class="fas fa-edit"></i> Edit</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" style="padding: 3rem; text-align: center; color: #94a3b8;">
                        No categories found. Click "New Category" to create one.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    
    <div style="margin-top: 20px;">
        <a href="{{ path('app_matiere_index') }}" style="color: #64748b; text-decoration: none; display: inline-flex; align-items: center; gap: 5px;">
            <i class="fas fa-arrow-left"></i> Back to Subjects
        </a>
    </div>
</div>
{% endblock %}