{% extends 'back/admin_base.html.twig' %}

{% block title %}New Subject - FAHIMNI Admin{% endblock %}

{% block body %}
    {# 
       1. INJECTING STYLES 
       We use the exact professional styling you provided to ensure the "Tags" look works.
    #}
    <style>
        /* --- VISUAL VARIABLES --- */
        :root {
            --bg: #f8fafc;
            --card: #ffffff;
            --muted: #6b7280;
            --text-primary: #0b1220;
            --border: #e2e8f0;
            --primary: #6c5ce7;
            --primary-grad: linear-gradient(90deg, #7c6cff 0%, #6c5ce7 100%);
            --radius: 12px;
            --shadow: 0 6px 18px rgba(11, 18, 32, 0.06);
        }

        /* --- PAGE LAYOUT --- */
        .admin-content { background-color: var(--bg); padding: 2.5rem; min-height: 100vh; }
        .page-header h1 { font-size: 1.75rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.25rem; }
        .page-header p { color: var(--muted); margin-bottom: 2rem; }

        /* --- FORM CARD --- */
        .form-card {
            background: var(--card); border-radius: var(--radius);
            border: 1px solid var(--border); padding: 2.5rem;
            box-shadow: var(--shadow); max-width: 850px;
        }
        .form-label { font-weight: 600; color: var(--text-primary); margin-bottom: 0.5rem; display: block; }
        .form-control {
            width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--border);
            border-radius: 8px; font-size: 0.95rem; background: #fff;
        }
        .form-control:focus {
            outline: none; border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(108, 92, 231, 0.1);
        }

        /* --- MAGIC: CHECKBOXES AS CLICKABLE TAGS --- */
        .category-selector { display: flex; flex-wrap: wrap; gap: 10px; }
        
        /* Hide the actual checkbox square */
        .category-selector input[type="checkbox"] { display: none; } 
        
        /* Style the label to look like a pill/button */
        .category-selector label {
            display: inline-block; padding: 8px 20px;
            border: 1px solid var(--border); border-radius: 50px;
            cursor: pointer; font-weight: 600; font-size: 0.9rem;
            color: var(--muted); background: #fff; transition: all 0.2s ease;
            user-select: none; /* Prevents text highlighting when clicking fast */
        }
        
        /* Hover state */
        .category-selector label:hover { border-color: #cbd5e1; background: #f8fafc; transform: translateY(-1px); }
        
        /* Checked state (The Magic) */
        .category-selector input[type="checkbox"]:checked + label {
            background: var(--primary-grad); border-color: transparent;
            color: white; box-shadow: 0 4px 10px rgba(108, 92, 231, 0.3);
            transform: translateY(-1px);
        }

        /* --- MINI BUTTON "Create New" --- */
        .btn-mini-add {
            font-size: 0.75rem; padding: 5px 12px; border-radius: 6px;
            background-color: #ede9fe; color: var(--primary);
            text-decoration: none; font-weight: 600; border: 1px solid transparent;
            transition: all 0.2s; display: inline-flex; align-items: center; gap: 4px;
        }
        .btn-mini-add:hover { background-color: var(--primary); color: white; }

        /* --- MAIN BUTTONS --- */
        .btn-submit {
            background: var(--primary-grad); color: white; padding: 0.8rem 1.5rem;
            border: none; border-radius: 8px; font-weight: 600; cursor: pointer;
            display: inline-flex; align-items: center; gap: 8px; transition: transform 0.2s;
        }
        .btn-submit:hover { transform: translateY(-2px); }
        .btn-cancel {
            background: transparent; color: var(--muted); border: 1px solid var(--border);
            padding: 0.8rem 1.5rem; border-radius: 8px; font-weight: 600;
            text-decoration: none; margin-left: 10px;
        }
        .btn-cancel:hover { background: #f3f4f6; color: var(--text-primary); }
    </style>

    <div class="page-header">
        <h1><i class="fas fa-plus-circle" style="color: var(--primary); margin-right: 8px;"></i> New Subject</h1>
        <p>Create a new subject and assign its categories</p>
    </div>

    <div class="form-card">
        {{ form_start(form) }}
            
            {# 1. Title #}
            <div style="margin-bottom: 1.5rem;">
                {{ form_label(form.titre, 'Subject Name', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.titre, {'attr': {'class': 'form-control', 'placeholder': 'e.g. Advanced Mathematics'}}) }}
                <div style="color: #ef4444; font-size: 0.875rem; margin-top: 5px;">{{ form_errors(form.titre) }}</div>
            </div>

            {# 2. Description #}
            <div style="margin-bottom: 1.5rem;">
                {{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': '4'}}) }}
                <div style="color: #ef4444; font-size: 0.875rem; margin-top: 5px;">{{ form_errors(form.description) }}</div>
            </div>

            {# 3. CATEGORIES (Moved ABOVE the Image and Save button) #}
            <div style="margin-bottom: 2rem; background: #f9faff; padding: 20px; border-radius: 12px; border: 1px dashed #dbeafe;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                    <label class="form-label" style="margin-bottom: 0;">Assign Categories</label>
                    
                    {# Ensure 'app_category_new' is your actual route for creating categories #}
                    <a href="{{ path('app_category_new') }}" target="_blank" class="btn-mini-add">
                        <i class="fas fa-plus"></i> Create Category
                    </a>
                </div>

                <div class="category-selector">
                    {# 
                       Using a loop to render each checkbox individually allows us 
                       to control the HTML structure for the CSS "Pill" effect.
                    #}
                    {% if form.categories is defined %}
                        {% for child in form.categories %}
                            {{ form_widget(child) }}
                            {{ form_label(child) }}
                        {% endfor %}
                    {% else %}
                        <div class="text-muted small">No categories found. Create one first.</div>
                    {% endif %}
                </div>
                
                <div style="font-size: 0.8rem; color: var(--muted); margin-top: 10px;">
                    <i class="fas fa-check-double"></i> Click tags to select multiple topics.
                </div>
                <div style="color: #ef4444; font-size: 0.875rem;">{{ form_errors(form.categories) }}</div>
            </div>

            {# 4. Image #}
            <div style="margin-bottom: 2rem;">
                {{ form_label(form.imageFile, 'Cover Image', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.imageFile, {'attr': {'class': 'form-control'}}) }}
                <div style="font-size: 0.8rem; color: var(--muted); margin-top: 6px;">
                    <i class="fas fa-cloud-upload-alt"></i> Upload a high-quality JPG or PNG.
                </div>
                <div style="color: #ef4444; font-size: 0.875rem;">{{ form_errors(form.imageFile) }}</div>
            </div>

            {# 5. Buttons (At the bottom) #}
            <div style="border-top: 1px solid var(--border); padding-top: 2rem;">
                <button type="submit" class="btn-submit">
                    <i class="fas fa-save"></i> Save Subject
                </button>
                <a href="{{ path('app_matiere_index') }}" class="btn-cancel">
                    Cancel
                </a>
            </div>

        {{ form_end(form) }}
    </div>
{% endblock %}