{% extends 'back/admin_base.html.twig' %}

{% block title %}Manage Subjects - FAHIMNI Admin{% endblock %}

{% block body %}
    {# 
       CRITICAL FIX: Injecting styles directly here because admin_base 
       ignores the {% block stylesheets %}.
    #}
    <style>
        /* --- 1. VISUAL VARIABLES (Consistent with Edit Page) --- */
        :root {
            --bg: #f8fafc;
            --card: #ffffff;
            --muted: #6b7280;
            --text-primary: #0b1220;
            --border: #e5e7eb;
            --primary: #6c5ce7;
            --primary-grad: linear-gradient(90deg, #7c6cff 0%, #6c5ce7 100%);
            --radius: 12px;
            --shadow: 0 6px 18px rgba(11, 18, 32, 0.06);
        }

        /* --- 2. SIDEBAR FIXES (Overrides admin_base) --- */
        .sidebar-container {
            background: linear-gradient(180deg, #3b2f63 0%, #2b2350 100%) !important;
            box-shadow: 0 12px 40px rgba(19, 24, 44, 0.25);
            border: none !important;
        }
        
        /* Clean up the lists in the sidebar */
        .sidebar-container ul { list-style: none; padding: 10px; margin: 0; }
        .sidebar-container li { margin: 4px 0; }

        /* Force white text and premium styling on links */
        .sidebar-container a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            color: rgba(255, 255, 255, 0.86) !important;
            text-decoration: none !important;
            border-radius: 10px;
            transition: all 0.2s ease;
            font-size: 0.95rem;
            font-weight: 500;
        }
        .sidebar-container a:hover {
            background: rgba(255, 255, 255, 0.08);
            color: #fff !important;
            transform: translateX(4px);
        }
        .sidebar-container a i { width: 24px; text-align: center; }


        /* --- 3. PAGE SPECIFIC STYLES (Cards & Grid) --- */
        .admin-content {
            background-color: var(--bg);
            padding: 2.5rem;
            min-height: 100vh;
        }

        /* Header Area */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2.5rem;
        }
        .page-header h1 {
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--text-primary);
            margin: 0 0 5px 0;
        }
        .page-header p { color: var(--muted); margin: 0; }

        .btn-create {
            background: var(--primary-grad);
            color: white !important;
            padding: 0.75rem 1.5rem;
            border-radius: 8px;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 4px 12px rgba(108, 92, 231, 0.25);
            transition: transform 0.2s;
        }
        .btn-create:hover { transform: translateY(-2px); }

        /* Grid Layout for Subjects */
        .subjects-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 1.5rem;
        }

        /* Subject Card Design */
        .subject-card {
            background: var(--card);
            border-radius: var(--radius);
            border: 1px solid var(--border);
            padding: 1.5rem;
            box-shadow: var(--shadow);
            transition: transform 0.2s, box-shadow 0.2s;
            display: flex;
            flex-direction: column;
        }
        .subject-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 25px rgba(11, 18, 32, 0.1);
        }

        .card-header {
            display: flex;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .subject-img {
            width: 60px;
            height: 60px;
            border-radius: 10px;
            object-fit: cover;
            background: #f1f5f9;
        }

        .subject-info h3 {
            margin: 0 0 5px 0;
            font-size: 1.1rem;
            color: var(--text-primary);
        }
        .subject-info p {
            margin: 0;
            font-size: 0.85rem;
            color: var(--muted);
            line-height: 1.4;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .card-actions {
            margin-top: auto; /* Pushes buttons to bottom */
            display: flex;
            gap: 10px;
            padding-top: 1rem;
            border-top: 1px solid #f1f5f9;
        }

        .action-btn {
            flex: 1;
            text-align: center;
            padding: 0.6rem;
            border-radius: 6px;
            font-size: 0.9rem;
            font-weight: 600;
            text-decoration: none;
            transition: background 0.2s;
        }

        .btn-view {
            background: #f8fafc;
            color: var(--text-primary);
            border: 1px solid var(--border);
        }
        .btn-view:hover { background: #e2e8f0; }

        .btn-edit {
            background: rgba(108, 92, 231, 0.1);
            color: var(--primary);
            border: 1px solid transparent;
        }
        .btn-edit:hover { background: rgba(108, 92, 231, 0.2); }

    </style>

    <div class="page-header">
        <div>
            <h1><i class="fas fa-book" style="color: var(--primary); margin-right: 10px;"></i> Subjects</h1>
            <p>Manage your learning subjects and materials</p>
        </div>
        <a href="{{ path('app_matiere_new') }}" class="btn-create">
            <i class="fas fa-plus"></i> New Subject
        </a>
    </div>

    <div class="subjects-grid">
        {% for matiere in matieres %}
            <div class="subject-card">
                <div class="card-header">
                    {% if matiere.coverImage %}
                        <img src="{{ asset(matiere.coverImage) }}" alt="{{ matiere.titre }}" class="subject-img">
                    {% else %}
                        <div class="subject-img" style="display:flex;align-items:center;justify-content:center;color:#cbd5e1;">
                            <i class="fas fa-image fa-lg"></i>
                        </div>
                    {% endif %}
                    
                    <div class="subject-info">
                        <h3>{{ matiere.titre }}</h3>
                        <p>{{ matiere.description }}</p>
                    </div>
                </div>

                <div class="card-actions">
                    {# 1. View Button #}
                    <a href="{{ path('app_matiere_show', {'id': matiere.id}) }}" class="action-btn btn-view" title="View Details">
                        <i class="fas fa-eye"></i>
                    </a>

                    {# 2. NEW: Manage Content Button #}
                    <a href="{{ path('app_course_manage', {'id': matiere.id}) }}" class="action-btn" style="background: #eef2ff; color: #4f46e5; flex: 2; border: 1px solid #c7d2fe;">
                        <i class="fas fa-layer-group"></i> <strong>Content</strong>
                    </a>

                    {# 3. Edit Button #}
                    <a href="{{ path('app_matiere_edit', {'id': matiere.id}) }}" class="action-btn btn-edit" title="Edit Settings">
                        <i class="fas fa-pen"></i>
                    </a>
                </div>
            </div>
        {% else %}
            <div style="grid-column: 1 / -1; text-align: center; padding: 4rem; color: var(--muted);">
                <i class="fas fa-folder-open" style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.5;"></i>
                <p>No subjects found. <a href="{{ path('app_matiere_new') }}" style="color: var(--primary);">Create one now?</a></p>
            </div>
        {% endfor %}
    </div>

{% endblock %}