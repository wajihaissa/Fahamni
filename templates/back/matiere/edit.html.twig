{% extends 'back/admin_base.html.twig' %}

{% block title %}Edit Subject - FAHIMNI Admin{% endblock %}

{% block body %}
    <style>
        /* --- 1. VISUAL VARIABLES --- */
        :root {
            --bg: #f8fafc;
            --card: #ffffff;
            --muted: #6b7280;
            --text-primary: #0b1220;
            --border: #e2e8f0;
            --primary: #6c5ce7;
            --primary-grad: linear-gradient(90deg, #7c6cff 0%, #6c5ce7 100%);
            --radius: 12px;
            --shadow: 0 6px 18px rgba(11, 18, 32, 0.06);
        }

        /* --- 2. SIDEBAR OVERRIDES --- */
        .sidebar-container {
            background: linear-gradient(180deg, #3b2f63 0%, #2b2350 100%) !important;
            box-shadow: 0 12px 40px rgba(19, 24, 44, 0.25);
            border: none !important;
        }
        .sidebar-container ul { list-style: none; padding: 10px; margin: 0; }
        .sidebar-container li { margin: 4px 0; }
        .sidebar-container a {
            display: flex; align-items: center; gap: 12px; padding: 12px 16px;
            color: rgba(255, 255, 255, 0.86) !important;
            text-decoration: none !important;
            border-radius: 10px; transition: all 0.2s ease;
            font-size: 0.95rem; font-weight: 500;
        }
        .sidebar-container a:hover {
            background: rgba(255, 255, 255, 0.08);
            color: #fff !important; transform: translateX(4px);
        }

        /* --- 3. PAGE STYLES --- */
        .admin-content { background-color: var(--bg); padding: 2.5rem; min-height: 100vh; }
        .page-header h1 { font-size: 1.75rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.25rem; }
        .page-header p { color: var(--muted); margin-bottom: 2rem; }

        /* --- 4. FORM STYLES --- */
        .form-card {
            background: var(--card); border-radius: var(--radius);
            border: 1px solid var(--border); padding: 2.5rem;
            box-shadow: var(--shadow); max-width: 850px;
            
            /* CRITICAL FIX: Allows us to position the delete button inside this box visually */
            position: relative; 
        }
        .form-label { font-weight: 600; color: var(--text-primary); margin-bottom: 0.5rem; display: block; }
        .form-control {
            width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--border);
            border-radius: 8px; font-size: 0.95rem; background: #fff;
        }
        .form-control:focus {
            outline: none; border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(108, 92, 231, 0.1);
        }

        /* --- 5. CHECKBOX PILLS --- */
        .category-selector { display: flex; flex-wrap: wrap; gap: 8px; }
        .category-selector input[type="checkbox"] { display: none; } 
        .category-selector label {
            display: inline-block; padding: 8px 16px;
            border: 1px solid var(--border); border-radius: 50px;
            cursor: pointer; font-weight: 600; font-size: 0.9rem;
            color: var(--muted); background: #fff; transition: all 0.2s ease;
        }
        .category-selector label:hover { border-color: #cbd5e1; background: #f8fafc; }
        .category-selector input[type="checkbox"]:checked + label {
            background-color: var(--primary); border-color: var(--primary);
            color: white; box-shadow: 0 4px 6px -1px rgba(108, 92, 231, 0.4);
        }

        /* --- 6. MINI BUTTON --- */
        .btn-mini-add {
            font-size: 0.75rem; padding: 4px 10px; border-radius: 6px;
            background-color: #ede9fe; color: var(--primary);
            text-decoration: none; font-weight: 600; border: 1px solid transparent;
            transition: all 0.2s;
        }
        .btn-mini-add:hover { background-color: var(--primary); color: white; }

        /* Buttons */
        .btn-submit {
            background: var(--primary-grad); color: white; padding: 0.8rem 1.5rem;
            border: none; border-radius: 8px; font-weight: 600; cursor: pointer;
            display: inline-flex; align-items: center; gap: 8px; transition: transform 0.2s;
        }
        .btn-submit:hover { transform: translateY(-2px); }
        .btn-cancel {
            background: transparent; color: var(--muted); border: 1px solid var(--border);
            padding: 0.8rem 1.5rem; border-radius: 8px; font-weight: 600;
            text-decoration: none; margin-left: 10px;
        }
        .btn-cancel:hover { background: #f3f4f6; color: var(--text-primary); }

        /* --- 7. DELETE CONTAINER (NEW) --- */
        .delete-btn-container {
            position: absolute;
            bottom: 2.5rem; /* Matches the padding of the card */
            right: 2.5rem;
        }
    </style>

    <div class="page-header">
        <h1><i class="fas fa-edit" style="color: var(--primary); margin-right: 8px;"></i> Edit Subject</h1>
        <p>Update the details for <strong>{{ matiere.titre }}</strong></p>
    </div>

    <div class="form-card">
        {# --- MAIN EDIT FORM STARTS --- #}
        {{ form_start(form) }}
            
            {# 1. Title #}
            <div style="margin-bottom: 1.5rem;">
                {{ form_label(form.titre, 'Subject Name', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.titre, {'attr': {'class': 'form-control', 'placeholder': 'e.g. Mathematics'}}) }}
                <div style="color: #ef4444; font-size: 0.875rem; margin-top: 5px;">{{ form_errors(form.titre) }}</div>
            </div>

            {# 2. Description #}
            <div style="margin-bottom: 1.5rem;">
                {{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': '5'}}) }}
                <div style="color: #ef4444; font-size: 0.875rem; margin-top: 5px;">{{ form_errors(form.description) }}</div>
            </div>

            {# 3. CATEGORIES #}
            <div style="margin-bottom: 2rem;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                    <label class="form-label" style="margin-bottom: 0;">Assign Categories</label>
                    <a href="{{ path('app_category_new') }}" target="_blank" class="btn-mini-add">
                        <i class="fas fa-plus"></i> Create New
                    </a>
                </div>

                <div class="category-selector">
                    {% if form.categories is defined %}
                        {% for child in form.categories %}
                            {{ form_widget(child) }}
                            {{ form_label(child) }}
                        {% endfor %}
                    {% else %}
                        <div class="alert alert-warning">Field 'categories' not found.</div>
                    {% endif %}
                </div>
                
                {% if form.categories is defined %}
                    <div style="color: #ef4444; font-size: 0.875rem; margin-top: 5px;">{{ form_errors(form.categories) }}</div>
                {% endif %}
            </div>

            {# 4. Image #}
            <div style="margin-bottom: 2rem;">
                {{ form_label(form.imageFile, 'Cover Image', {'label_attr': {'class': 'form-label'}}) }}
                
                {% if matiere.coverImage %}
                    <div class="current-image-preview">
                        <div style="font-size: 0.7rem; font-weight: 700; color: var(--muted); text-transform: uppercase; margin-bottom: 6px;">Current Image</div>
                        <img src="{{ asset(matiere.coverImage) }}" alt="Current Cover" style="height: 100px; border-radius: 6px;">
                    </div>
                {% endif %}

                {{ form_widget(form.imageFile, {'attr': {'class': 'form-control'}}) }}
                <div style="font-size: 0.85rem; color: var(--muted); margin-top: 6px;">
                    <i class="fas fa-info-circle"></i> Leave empty to keep the current image.
                </div>
                <div style="color: #ef4444; font-size: 0.875rem;">{{ form_errors(form.imageFile) }}</div>
            </div>

            {# Buttons - ONLY SAVE AND CANCEL HERE #}
            <div style="border-top: 1px solid var(--border); padding-top: 2rem; display: flex; align-items: center;">
                <button type="submit" class="btn-submit">
                    <i class="fas fa-save"></i> Save Changes
                </button>
                <a href="{{ path('app_matiere_index') }}" class="btn-cancel">Cancel</a>
            </div>

        {{ form_end(form) }}
        {# --- FORM ENDS HERE. TOKEN IS SAVED. --- #}

        {# --- SEPARATE DELETE FORM (Positioned by CSS) --- #}
        <div class="delete-btn-container">
            {{ include('back/matiere/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}