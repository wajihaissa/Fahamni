{% extends 'back/admin_base.html.twig' %}

{% block title %}Course Builder - {{ matiere.titre }}{% endblock %}

{% block body %}
    {# 
       CRITICAL STYLE INJECTION 
       Matches the design of your 'Manage Subjects' page perfectly.
    #}
    <style>
        /* --- 1. VISUAL VARIABLES (Consistent with Index Page) --- */
        :root {
            --bg: #f8fafc;
            --card: #ffffff;
            --muted: #6b7280;
            --text-primary: #0b1220;
            --border: #e5e7eb;
            --primary: #6c5ce7;
            --primary-grad: linear-gradient(90deg, #7c6cff 0%, #6c5ce7 100%);
            --radius: 12px;
            --shadow: 0 6px 18px rgba(11, 18, 32, 0.06);
            --danger: #ef4444;
            --success: #10b981;
        }

        /* --- 2. SIDEBAR FIXES (Overrides admin_base) --- */
        .sidebar-container {
            background: linear-gradient(180deg, #3b2f63 0%, #2b2350 100%) !important;
            box-shadow: 0 12px 40px rgba(19, 24, 44, 0.25);
            border: none !important;
        }
        
        /* Clean up the lists in the sidebar */
        .sidebar-container ul { list-style: none; padding: 10px; margin: 0; }
        .sidebar-container li { margin: 4px 0; }

        /* Force white text and premium styling on links */
        .sidebar-container a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            color: rgba(255, 255, 255, 0.86) !important;
            text-decoration: none !important;
            border-radius: 10px;
            transition: all 0.2s ease;
            font-size: 0.95rem;
            font-weight: 500;
        }
        .sidebar-container a:hover {
            background: rgba(255, 255, 255, 0.08);
            color: #fff !important;
            transform: translateX(4px);
        }
        .sidebar-container a i { width: 24px; text-align: center; }

        /* --- 3. PAGE SPECIFIC STYLES --- */
        .admin-content {
            background-color: var(--bg);
            padding: 2.5rem;
            min-height: 100vh;
        }

        /* Header Area */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2.5rem;
        }
        .page-header h1 {
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--text-primary);
            margin: 0 0 5px 0;
        }
        .page-header p { color: var(--muted); margin: 0; }

        .btn-back {
            background: white;
            color: var(--text-primary);
            padding: 0.75rem 1.5rem;
            border-radius: 8px;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border: 1px solid var(--border);
            transition: transform 0.2s;
        }
        .btn-back:hover { transform: translateY(-2px); background: #f1f5f9; }

        /* --- 4. COURSE BUILDER COMPONENTS --- */

        /* Chapter Card */
        .chapter-card {
            background: var(--card);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            margin-bottom: 2rem;
            overflow: hidden;
            transition: transform 0.2s;
        }
        .chapter-header {
            background: #f8fafc;
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .chapter-title {
            font-weight: 800;
            color: var(--text-primary);
            font-size: 1.1rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* Section Block */
        .section-block {
            margin: 1.5rem;
            background: #ffffff;
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
        }
        .section-header {
            padding: 1rem 1.25rem;
            background: #f1f5f9;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .section-title {
            font-weight: 700;
            color: #475569;
            font-size: 0.95rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* Resource Items */
        .resource-list { padding: 10px 15px; display: flex; flex-direction: column; gap: 8px; }
        
        .resource-item {
            display: flex;
            align-items: center;
            padding: 10px 14px;
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            transition: all 0.2s ease;
        }
        .resource-item:hover {
            border-color: var(--primary);
            box-shadow: 0 2px 8px rgba(108, 92, 231, 0.1);
            transform: translateX(4px);
        }

        /* Icons */
        .res-icon {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 14px;
            font-size: 1rem;
        }
        .icon-video { background: #e0e7ff; color: #4f46e5; }
        .icon-pdf { background: #fee2e2; color: #ef4444; }
        .icon-link { background: #ecfccb; color: #65a30d; }

        .res-info { flex: 1; }
        .res-title { font-size: 0.95rem; font-weight: 600; color: var(--text-primary); margin: 0; }
        
        /* Links in Metadata */
        .res-meta a { font-size: 0.8rem; font-weight: 500; transition: opacity 0.2s; }
        .res-meta a:hover { opacity: 0.8; text-decoration: underline; }

        /* Action Buttons */
        .btn-icon-danger {
            color: #ef4444;
            background: rgba(239, 68, 68, 0.1);
            width: 32px; height: 32px;
            display: flex; align-items: center; justify-content: center;
            border-radius: 6px;
            transition: all 0.2s;
            text-decoration: none;
        }
        .btn-icon-danger:hover { background: #ef4444; color: white; }

        /* Forms */
        .add-resource-btn {
            background: transparent;
            color: var(--muted);
            width: 100%;
            padding: 10px;
            border: none;
            border-top: 1px dashed var(--border);
            text-align: left;
            cursor: pointer;
            font-size: 0.85rem;
            font-weight: 600;
            transition: background 0.2s;
        }
        .add-resource-btn:hover { background: #f8fafc; color: var(--primary); }

        .resource-adder {
            background: #f8fafc;
            padding: 15px;
            border-top: 1px solid var(--border);
            display: none;
        }
        
        .input-theme {
            width: 100%;
            padding: 10px;
            border: 1px solid var(--border);
            border-radius: 6px;
            font-size: 0.9rem;
            outline: none;
            transition: border-color 0.2s;
        }
        .input-theme:focus { border-color: var(--primary); }
        
        .btn-primary-theme {
            background: var(--primary-grad);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 6px;
            font-weight: 600;
            cursor: pointer;
            box-shadow: 0 4px 12px rgba(108, 92, 231, 0.2);
        }
        .btn-primary-theme:hover { transform: translateY(-1px); }

        /* New Chapter Area */
        .new-chapter-area {
            background: #eef2ff;
            border: 2px dashed #818cf8;
            border-radius: var(--radius);
            padding: 3rem;
            text-align: center;
            margin-top: 3rem;
        }
    </style>

    <div class="page-header">
        <div>
            <h1><i class="fas fa-layer-group" style="color: var(--primary); margin-right: 10px;"></i> Course Builder</h1>
            <p>Managing content for: <strong style="color: var(--text-primary);">{{ matiere.titre }}</strong></p>
        </div>
        <a href="{{ path('app_matiere_index') }}" class="btn-back">
            <i class="fas fa-arrow-left"></i> Back to Subjects
        </a>
    </div>

    {% for chapter in matiere.chapters %}
        <div class="chapter-card">
            <div class="chapter-header">
                <span class="chapter-title">
                    <i class="fas fa-folder-open" style="color: var(--primary);"></i> 
                    {{ chapter.titre }}
                </span>
                <a href="{{ path('app_chapter_delete', {id: chapter.id}) }}" class="btn-icon-danger" onclick="return confirm('Delete Chapter and all its contents?');" title="Delete Chapter">
                    <i class="fas fa-trash-alt"></i>
                </a>
            </div>

            {% for section in chapter.sections %}
                <div class="section-block">
                    <div class="section-header">
                        <span class="section-title"><i class="fas fa-list-ul"></i> {{ section.titre }}</span>
                        <a href="{{ path('app_section_delete', {id: section.id}) }}" style="color: #ef4444; font-size: 0.8rem; text-decoration: none;" onclick="return confirm('Delete Section?');">
                            <i class="fas fa-times"></i> Delete Section
                        </a>
                    </div>

                    <div class="resource-list">
                        {% for resource in section.resources %}
                            <div class="resource-item">
                                <div class="res-icon {{ resource.type == 'video' ? 'icon-video' : (resource.type == 'pdf' ? 'icon-pdf' : 'icon-link') }}">
                                    {% if resource.type == 'video' %}<i class="fas fa-play"></i>{% endif %}
                                    {% if resource.type == 'pdf' %}<i class="fas fa-file-pdf"></i>{% endif %}
                                    {% if resource.type == 'link' %}<i class="fas fa-link"></i>{% endif %}
                                </div>

                                <div class="res-info">
                                    <p class="res-title">{{ resource.titre }}</p>
                                    <div class="res-meta">
                                        {# FIXED LINKS: Opening in new tabs correctly #}
                                        {% if resource.type == 'video' %}
                                            <a href="{{ asset('uploads/course_content/' ~ resource.filePath) }}" target="_blank" style="color: #4f46e5; text-decoration: none;">
                                                <i class="fas fa-play-circle"></i> Watch Video
                                            </a>
                                        {% elseif resource.type == 'pdf' %}
                                            <a href="{{ asset('uploads/course_content/' ~ resource.filePath) }}" target="_blank" style="color: #ef4444; text-decoration: none;">
                                                <i class="fas fa-file-download"></i> Download PDF
                                            </a>
                                        {% elseif resource.type == 'link' %}
                                            <a href="{{ resource.link }}" target="_blank" style="color: #65a30d; text-decoration: none;">
                                                {{ resource.link }} <i class="fas fa-external-link-alt"></i>
                                            </a>
                                        {% endif %}
                                    </div>
                                </div>
                                
                                <a href="{{ path('app_resource_delete', {id: resource.id}) }}" class="btn-icon-danger" style="background:transparent; width:auto;" onclick="return confirm('Delete resource?');">
                                    <i class="fas fa-trash-alt"></i>
                                </a>
                            </div>
                        {% else %}
                            <div style="text-align:center; padding: 15px; color: var(--muted); font-size: 0.85rem; font-style: italic;">
                                No resources added yet.
                            </div>
                        {% endfor %}
                    </div>

                    <button class="add-resource-btn" onclick="toggleResourceForm('form-sec-{{ section.id }}')">
                        <i class="fas fa-plus-circle"></i> Add Resource to "{{ section.titre }}"
                    </button>

                    <div id="form-sec-{{ section.id }}" class="resource-adder">
                        <form action="{{ path('app_resource_add', {id: section.id}) }}" method="POST" enctype="multipart/form-data">
                            <div style="display:flex; gap:10px; margin-bottom:10px;">
                                <input type="text" name="title" class="input-theme" placeholder="Resource Title (e.g. Introduction Video)" style="flex:2;" required>
                                <select name="type" class="input-theme" style="flex:1;" onchange="toggleInputs(this)">
                                    <option value="video">Video (MP4)</option>
                                    <option value="pdf">PDF File</option>
                                    <option value="link">Link (YouTube/Web)</option>
                                </select>
                            </div>
                            
                            <div class="file-group">
                                <label style="font-size:0.8rem; color:var(--muted); display:block; margin-bottom:4px;">Upload File</label>
                                <input type="file" name="file_upload" class="input-theme" style="background:white;">
                            </div>
                            <div class="link-group" style="display:none;">
                                <label style="font-size:0.8rem; color:var(--muted); display:block; margin-bottom:4px;">Paste URL</label>
                                <input type="url" name="link_url" class="input-theme" placeholder="https://...">
                            </div>

                            <button type="submit" class="btn-primary-theme" style="width:100%; margin-top:10px;">
                                <i class="fas fa-cloud-upload-alt"></i> Upload Resource
                            </button>
                        </form>
                    </div>
                </div>
            {% else %}
                <div style="padding: 3rem; text-align: center; color: var(--muted);">
                    <i class="fas fa-inbox" style="font-size: 2rem; opacity: 0.3; margin-bottom: 10px;"></i>
                    <p>This chapter is empty. Start by adding a section below.</p>
                </div>
            {% endfor %}

            <div style="padding: 1.5rem; background: #fff; border-top: 1px dashed var(--border);">
                <form action="{{ path('app_section_add', {id: chapter.id}) }}" method="POST" style="display: flex; gap: 10px;">
                    <input type="text" name="title" class="input-theme" placeholder="New Section Name (e.g. 1.1 Getting Started)" style="flex:1;" required>
                    <button type="submit" class="btn-primary-theme" style="background: #334155; box-shadow:none;">+ Add Section</button>
                </form>
            </div>
        </div>
    {% endfor %}

    <div class="new-chapter-area">
        <h3 style="color: #4338ca; margin-top:0;">Create New Chapter</h3>
        <p style="color: #6366f1; margin-bottom: 1.5rem;">Organize your course by adding a new chapter module.</p>
        <form action="{{ path('app_chapter_add', {id: matiere.id}) }}" method="POST" style="max-width: 500px; margin: 0 auto; display: flex; gap: 10px;">
            <input type="text" name="title" class="input-theme" placeholder="Chapter Title (e.g. Chapter 1: Basics)" style="flex:1;" required>
            <button type="submit" class="btn-primary-theme">Create Chapter</button>
        </form>
    </div>

    <script>
        function toggleResourceForm(id) {
            const el = document.getElementById(id);
            el.style.display = (el.style.display === 'block') ? 'none' : 'block';
        }

        function toggleInputs(select) {
            const form = select.closest('form');
            const fileGroup = form.querySelector('.file-group');
            const linkGroup = form.querySelector('.link-group');

            if (select.value === 'link') {
                fileGroup.style.display = 'none';
                linkGroup.style.display = 'block';
            } else {
                fileGroup.style.display = 'block';
                linkGroup.style.display = 'none';
            }
        }
    </script>
{% endblock %}