<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - {% block title %}Dashboard{% endblock %}</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            if (savedTheme === 'dark') {
                document.documentElement.setAttribute('data-bs-theme', 'dark');
            }
        })();
    </script>
    
    <style>
        body { min-height: 100vh; display: flex; }
        .admin-wrapper { display: flex; width: 100%; }
        .sidebar-container { min-width: 260px; max-width: 260px; min-height: 100vh; background: #212529; color: white; }
        .content-container { flex-grow: 1; display: flex; flex-direction: column; }
        .admin-content { padding: 20px; flex-grow: 1; overflow-y: auto; }
    </style>

    {% block stylesheets %}{% endblock %}
</head>
<body>

<div class="admin-wrapper">
    <aside class="sidebar-container">
        {% include 'back/_sidebar.html.twig' %}
    </aside>

    <div class="content-container">
        {% include 'back/_admin_navbar.html.twig' %}

        <main class="admin-content">
            {% block body %}{% endblock %}
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}

</body>
</html>